# Coyote's Dune Delivery — Environment Variables
    # Copy this file to .env and fill in your real values.

    # Server
    PORT=3000
    NODE_ENV=development

    # Authentication (generate a strong secret for production)
    JWT_SECRET=change-me-to-a-random-strong-secret

    # Admin default password (used only when seeding the first admin user)
    ADMIN_PASSWORD=coyote2024

    # Uploads
    UPLOAD_DIR=./uploads

    # Optional: custom DB path (defaults to ./backend/coyote.db)
    # DB_PATH=./coyote.db
    